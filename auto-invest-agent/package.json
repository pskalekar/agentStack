{
  "name": "auto-invest-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "An agent that automatically invests idle USDC to earn yield and pays for services just-in-time. Testnet only. Personal exploration — not an official Circle product.",
  "scripts": {
    "verify-earn": "tsx src/scripts/verify-earn.ts",
    "demo": "tsx src/scripts/demo.ts",
    "agent": "tsx src/scripts/agent.ts",
    "dashboard": "next dev -p 3007",
    "build:dashboard": "next build",
    "start:dashboard": "next start -p 3007",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.19"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.8"
  }
}
