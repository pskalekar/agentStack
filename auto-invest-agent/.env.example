# --- Network (Arc testnet; USDC is the native gas token) ---
RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002

# --- Token + vault ---
# USDC ERC-20 on Arc testnet.
USDC_ADDRESS=0x3600000000000000000000000000000000000000
# ERC-4626 yield vault to invest into. Leave blank until you've picked one.
# Find/verify a vault on https://testnet.arcscan.app — its asset() MUST equal USDC_ADDRESS.
VAULT_ADDRESS=

# --- Wallet ---
# Testnet wallet private key. TESTNET FUNDS ONLY — never a real key.
# Leave blank to run verify-earn in read-only mode (no transactions).
AGENT_PRIVATE_KEY=

# --- Agent policy (sized in TASKS; per-task = TASK_COST_USDC + GAS_PER_TASK_USDC) ---
# Approximate cost per task.
TASK_COST_USDC=0.1
# Gas headroom per task (gas is paid in USDC on Arc, same balance).
GAS_PER_TASK_USDC=0.01
# High-water liquid buffer, in tasks (buffer = BUFFER_TASKS × per-task).
BUFFER_TASKS=10
# Low-water refill trigger, in tasks. When liquid drops below this many tasks'
# worth, the agent refills back up to the buffer in one withdrawal.
LOW_WATER_TASKS=5
# Don't sweep idle USDC smaller than this (avoids deposits whose gas rivals the
# amount invested). Defaults to one task's cost if unset.
MIN_SWEEP_USDC=0.1
# Loop interval, seconds (continuous mode: `npm run agent`).
TICK_SECONDS=15
# Continuous mode: pay a task every N ticks (0 = sweep idle funds only, no tasks).
TASK_EVERY_TICKS=3

# --- verify-earn script ---
# Amount of USDC to round-trip through the vault when testing.
VERIFY_AMOUNT_USDC=0.1

# --- demo script ---
# Where the demo "service payment" is sent (any testnet address you like).
PAYEE_ADDRESS=
# How many tasks the demo runs — enough to drain the buffer and trigger refills.
DEMO_TASKS=12
# USDC the agent always keeps for gas (gas is paid in USDC on Arc, from the same
# balance — so the agent can never spend down to zero).
GAS_RESERVE_USDC=0.02

# --- dashboard (optional) ---
# Address the dashboard displays. Defaults to deriving from AGENT_PRIVATE_KEY.
AGENT_ADDRESS=
